# Copy this file to .env and fill in your Meta App credentials
META_APP_ID=your_app_id_here
META_APP_SECRET=your_app_secret_here
REDIRECT_URI=http://localhost:8000/auth/callback
FRONTEND_URL=http://localhost:5173

# Snapchat Marketing API credentials
SNAP_PUBLIC_CLIENT_ID=your_snapchat_public_client_id_here
SNAP_CLIENT_ID=your_snapchat_confidential_client_id_here
SNAP_CLIENT_SECRET=your_snapchat_client_secret_here
SNAP_REDIRECT_URI=http://localhost:8000/snap/auth/callback
